# Secrets & personal data — NEVER commit (this is a public repo).
# settings.json holds your Gemini/Anthropic API keys; the others hold personal state.
settings.json
settings.local.json
memory.json
automations.json
chat_history.json
chat_history/
*.key
*.pem
.env

# Runtime state for backlog features (encrypted vault, usage, snippets, recordings).
# The source now lives in "System Files/", so a source run writes these there. Anchored to
# that folder so the workflow_recorder's workflows/ data dir does NOT shadow .github/workflows/
# (the CI definitions).
/System Files/vault.enc
/System Files/usage.json
/System Files/snippets.json
/System Files/workflows/
/System Files/recordings/
# (legacy root locations from before the System Files/ move)
/vault.enc
/usage.json
/snippets.json
/recordings/

# Captured screen content
screenshots/
*.jpg
*.jpeg

# Build artifacts (large; regenerated by the build/release scripts)
build/
dist/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.eggs/

# Editor / preview scratch
.claude/

# Updater swap temp / OS cruft
*.old
.DS_Store
**/.DS_Store
Thumbs.db

# Logs
*.log

# Runtime crash log (written by _install_crash_guards)
ember-crash.log

# Update signing private key — NEVER commit
update_privkey.pem
